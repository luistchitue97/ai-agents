// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AgentStatus {
  active
  idle
  paused
}

enum LogLevel {
  info
  success
  warning
  error
}

enum AgentRunStatus {
  pending
  running
  succeeded
  failed
}

enum AgentRunStepKind {
  prompt
  response
  error
  tool_call
  tool_result
}

model Agent {
  id              Int         @id @default(autoincrement())
  organizationId  String
  name            String
  nameKey         String
  description     String
  model           String
  status          AgentStatus @default(idle)
  tasksCompleted  Int         @default(0)
  lastActive      DateTime    @default(now())
  capabilities    String[]
  // Scheduling (Phase 4). cron is a 5-field cron expression interpreted in `timezone`.
  cron            String?
  timezone        String      @default("UTC")
  scheduleEnabled Boolean     @default(false)
  nextRunAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  logs            Log[]
  connections     AgentConnection[]
  runs            AgentRun[]

  @@unique([organizationId, nameKey])
  @@index([organizationId])
  @@index([scheduleEnabled, nextRunAt])
}

model IntegrationConnection {
  id              String    @id @default(cuid())
  organizationId  String
  providerId      String
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime?
  scope           String?
  accountId       String?
  accountLogin    String?
  accountName     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  agentConnections AgentConnection[]

  @@unique([organizationId, providerId, accountId])
  @@index([organizationId])
}

model AgentConnection {
  agentId                 Int
  integrationConnectionId String
  createdAt               DateTime @default(now())
  agent                   Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  connection              IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)

  @@id([agentId, integrationConnectionId])
  @@index([integrationConnectionId])
}

model AgentRun {
  id               String         @id @default(cuid())
  agentId          Int
  organizationId   String
  status           AgentRunStatus @default(pending)
  triggeredById    String
  triggeredByName  String
  triggeredByEmail String
  summary          String?
  errorMessage     String?
  startedAt        DateTime       @default(now())
  finishedAt       DateTime?
  createdAt        DateTime       @default(now())
  agent            Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  steps            AgentRunStep[]

  @@index([agentId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
}

model AgentRunStep {
  id         String           @id @default(cuid())
  runId      String
  sequence   Int
  kind       AgentRunStepKind
  content    String?
  toolName   String?
  toolInput  Json?
  toolOutput Json?
  createdAt  DateTime         @default(now())
  run        AgentRun         @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, sequence])
}

model Log {
  id         Int      @id @default(autoincrement())
  agentId    Int
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  level      LogLevel
  message    String
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([agentId, createdAt(sort: Desc)])
}

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  actorEmail     String
  actorName      String
  action         String
  targetType     String?
  targetId       String?
  targetLabel    String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
}

model Notification {
  id             String    @id @default(cuid())
  organizationId String
  recipientId    String
  type           String
  title          String
  body           String?
  link           String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
}
